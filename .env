# Frontend .env
# File này đặt ở thư mục gốc (cùng cấp với package.json)

# API Backend URL (optional - có default fallback)
VITE_API_BASE=http://localhost:3001/api

# Firebase Config (optional - đã có trong config.js)
# VITE_FIREBASE_API_KEY=AIzaSyAr4nGRhlqXyoHG7dZtqcbj-IN2Xcr0LqM
# VITE_FIREBASE_AUTH_DOMAIN=fir-auth-cozy.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=fir-auth-cozy

# Development settings
VITE_DEV_MODE=true
VITE_LOG_LEVEL=info